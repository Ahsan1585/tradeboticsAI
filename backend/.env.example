# Copy to .env for local dev. On Render, set these as environment variables.
# NEVER commit the real .env.

# Supabase (rotate the service key — the old one is burned; see migrations/ for SQL to run)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-rotated-service-role-key

# JWT verification (Phase 0 auth):
# - Legacy Supabase projects: paste Project Settings -> API -> JWT Secret here.
# - New projects with asymmetric signing keys: leave unset; JWKS is used automatically.
SUPABASE_JWT_SECRET=

# Anthropic Claude (replaces Gemini). Create at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Optional per-purpose model overrides (default claude-haiku-4-5):
# LLM_MODEL_DEFAULT=claude-haiku-4-5
# LLM_MODEL_DEEP_DIVE=claude-sonnet-5

# News/quotes
FINNHUB_API_KEY=your-rotated-finnhub-key

# CORS allowlist (comma-separated)
FRONTEND_ORIGINS=https://your-app.vercel.app,http://localhost:3000
